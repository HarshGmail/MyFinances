{
  "name": "MyFinances",
  "version": "1.0.0",
  "description": "My Finance Application",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:mcp\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:mcp": "cd mcp-server && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:mcp": "cd mcp-server && npm run build",
    "build": "npm run build:frontend && npm run build:backend && npm run build:mcp",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "lint:mcp": "cd mcp-server && npm run lint",
    "lint": "npm run lint:frontend && npm run lint:backend && npm run lint:mcp",
    "lint:strict:frontend": "cd frontend && npm run lint:strict",
    "lint:strict:backend": "cd backend && npm run lint",
    "lint:strict:mcp": "cd mcp-server && npm run lint",
    "lint:strict": "npm run lint:strict:frontend && npm run lint:strict:backend && npm run lint:strict:mcp",
    "prettier:check:frontend": "cd frontend && npm run prettier:check",
    "prettier:check:backend": "cd backend && npm run prettier:check",
    "prettier:check:mcp": "cd mcp-server && npm run prettier:check",
    "prettier:check": "npm run prettier:check:frontend && npm run prettier:check:backend && npm run prettier:check:mcp",
    "prettier:auto": "node scripts/prettier-auto.js",
    "prettier:frontend": "cd frontend && npm run prettier:fix",
    "prettier:backend": "cd backend && npm run prettier:fix",
    "prettier:mcp": "cd mcp-server && npm run prettier:fix",
    "prettier:all": "npm run prettier:frontend && npm run prettier:backend && npm run prettier:mcp",
    "fmt:rust": "cargo fmt --manifest-path pdf-parsing/Cargo.toml",
    "fmt:rust:check": "cargo fmt --manifest-path pdf-parsing/Cargo.toml -- --check",
    "fmt": "npm run prettier:all && npm run fmt:rust",
    "fmt:check": "npm run prettier:check && npm run fmt:rust:check",
    "deploy:check": "node scripts/deploy-check.js",
    "deploy": "node scripts/deploy.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "node-cron": "^3.0.3"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "cors": "^2.8.5"
  }
}
