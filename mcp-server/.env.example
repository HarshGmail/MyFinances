# Port for the MCP HTTP server
PORT=4000

# Backend API base URL
# Local dev: http://localhost:5000/api
# Production: https://api.my-finances.site/api
BACKEND_URL=http://localhost:5000/api

# Public URL of this MCP server (used in OAuth metadata + WWW-Authenticate)
# Local dev: http://localhost:4000
# Production: https://mcp.my-finances.site
SITE_URL=https://mcp.my-finances.site

# Frontend URL — OAuth authorize redirects here for the seamless connect page
# Local dev: http://localhost:3000
# Production: https://www.my-finances.site
FRONTEND_URL=https://www.my-finances.site
